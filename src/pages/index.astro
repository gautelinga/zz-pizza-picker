---
import PizzaPicker from '../components/PizzaPicker.svelte';
// Generated by `npm run scrape` (runs automatically via prebuild).
// Do NOT call `astro build` directly — use `npm run build`.
import menuData from '../../public/menu.json';
import type { MenuData } from '../types/pizza';
import '../styles/global.css';

// Type-narrow the JSON import so downstream changes to menu.json shape
// surface as build errors rather than runtime surprises.
const menu = menuData as MenuData;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ZZ Pizza Picker</title>
  </head>
  <body class="min-h-screen flex items-center justify-center bg-neutral-50 text-neutral-900">
    <PizzaPicker pizzas={menu.pizzas} client:load />
  </body>
</html>
